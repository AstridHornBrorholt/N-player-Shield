	<declaration>/**
Every production unit has two outputs which feed into other production units or to outlets.
If a production unit doesn't receive output from another unit, it receives it from an intake that delivers material according to a cyclic pattern.
*/
clock time;    // Used as exit condition for the strategy queries
const int N = 23; // Number of units + providers
const int N_PROVIDERS = 10; // Number of just providers
const int L = 0;    // Constant to add if this is a left output
const int R = N; // Constant to add if this is a right output
typedef int[0, N - 1] UnitID;
typedef int[0, N_PROVIDERS - 1] CostID;
typedef int[0, N*2 - 1] OutputID;

const double MIN_STORED = 2;       // Unit: L
const double MAX_STORED = 20;      // Unit: L
const double RATE = 1;  // Unit: L/m

// Material stored in each tank. Unit: L
clock stored[N] = {11, 11, 11, 11, 11, 11, 11, 11, 11, 11, 11, 11, 11, 11, 11, 11, 11, 11, 11, 11, 11, 11, 11};
clock cost[N_PROVIDERS];
double output[N*2];   // Outputs of production unit. Left outputs are indexed by unit_id+L = unit_id, right outputs by unit_id+R. Unit: L/h


/** Shielding **/

const int INPUT_THREE = 3;
const int INPUT_TWO = 2;
const int INPUT_ONE = 1;
const int WAIT = 0;

import "/home/asger/Documents/Files/Arbejde/AAU/Artikler/N-player Shield/CP/libcpshield.so"
{
    int get_value(double volume);
};

double debug1 = get_value(5);

typedef struct {
    bool wait;
    bool input_one;
    bool input_two;
    bool input_three;
} allowedActions;

allowedActions intToActions(int bitarray) {
    allowedActions result = { 
        (0 != (bitarray &amp; (1 &lt;&lt; 0))),
        (0 != (bitarray &amp; (1 &lt;&lt; 1))),
        (0 != (bitarray &amp; (1 &lt;&lt; 2))),
        (0 != (bitarray &amp; (1 &lt;&lt; 3)))
    };
    return result;
}

int debugUnsafeState = 0;

allowedActions get_allowed(UnitID i) {
    double V = stored[i]+0.0;    // This is how to convert clock to double.  
    allowedActions allowed = intToActions(get_value(V));
    allowedActions any = {true, true, true, true};
    if (!allowed.wait &amp;&amp; !allowed.input_one &amp;&amp; !allowed.input_two &amp;&amp; !allowed.input_three) {
        debugUnsafeState = 1;
        return any;
    }
    return allowed;
}
